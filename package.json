{
  "name": "lunch-table",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run dev:web",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:bot": "bun run --cwd apps/bot-runner dev",
    "build": "bun run build:web && bun run build:bot",
    "build:web": "bun run --cwd apps/web build",
    "build:bot": "bun run --cwd apps/bot-runner build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:rules": "vitest run packages/game-core/src",
    "test:replay": "vitest run tests/replay-contract.test.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.6.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "typescript": "^5.9.3",
    "viem": "2.47.6",
    "vite": "^7.1.10",
    "vitest": "^3.2.4"
  }
}
