{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "allowJs": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@lunchtable/shared-types": ["packages/shared-types/src/index.ts"],
      "@lunchtable/game-core": ["packages/game-core/src/index.ts"],
      "@lunchtable/games-core": ["packages/games-core/src/index.ts"],
      "@lunchtable/games-ai": ["packages/games-ai/src/index.ts"],
      "@lunchtable/games-render": ["packages/games-render/src/index.ts"],
      "@lunchtable/games-tabletop": ["packages/games-tabletop/src/index.ts"],
      "lunchtable": ["packages/cli/src/index.ts"],
      "@lunchtable/bot-sdk": ["packages/bot-sdk/src/index.ts"],
      "@lunchtable/card-content": ["packages/card-content/src/index.ts"],
      "@lunchtable/render-pixi": ["packages/render-pixi/src/index.ts"],
      "@lunchtable/render-pixi/react": [
        "packages/render-pixi/src/PixiMatchBoard.tsx"
      ]
    },
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "convex/**/*.ts",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "tests/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "dist", "packages/*/dist", "coverage"]
}
